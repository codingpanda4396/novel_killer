{
  "provider": {
    "type": "openai_compatible",
    "base_url": "https://api.openai.com/v1",
    "api_key_env": "OPENAI_API_KEY"
  },
  "defaults": {
    "temperature": 0.7,
    "max_tokens": 6000
  },
  "stages": {
    "build_context": {
      "model": "gpt-5.4-mini",
      "temperature": 0.2,
      "max_tokens": 5000
    },
    "scene_card": {
      "model": "gpt-5.4",
      "temperature": 0.4,
      "max_tokens": 5000
    },
    "draft": {
      "model": "gpt-5.5",
      "temperature": 0.8,
      "max_tokens": 9000
    },
    "review": {
      "model": "gpt-5.4",
      "temperature": 0.2,
      "max_tokens": 5000
    },
    "rewrite": {
      "model": "gpt-5.5",
      "temperature": 0.7,
      "max_tokens": 9000
    },
    "update_record": {
      "model": "gpt-5.4",
      "temperature": 0.2,
      "max_tokens": 9000
    },
    "continuity_check": {
      "model": "gpt-5.4",
      "temperature": 0.1,
      "max_tokens": 5000
    },
    "next_planner": {
      "model": "gpt-5.4",
      "temperature": 0.3,
      "max_tokens": 5000
    }
  }
}
